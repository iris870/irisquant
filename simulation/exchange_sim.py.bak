import random
import time
import json
import os
import sys
from dataclasses import dataclass
from typing import Dict, Optional, Tuple

# 添加统一余额服务
sys.path.insert(0, "/root/irisquant")
from services.balance_service import balance_service

try:
    from core.logger import setup_logger
except ModuleNotFoundError:
    import logging
    def setup_logger(name):
        logger = logging.getLogger(name)
        if not logger.handlers:
            handler = logging.StreamHandler()
            handler.setFormatter(logging.Formatter('%(asctime)s [%(levelname)s] %(message)s'))
            logger.addHandler(handler)
        return logger

@dataclass
class Position:
    symbol: str
    amount: float
    entry_price: float
    side: str = "long"
    timestamp: float = 0.0

class SimulatedAccount:
    _exchange = None
    def __init__(self, account_id: str, initial_balance: float, risk_config: Dict):
        self.account_id = account_id
        self.balance = initial_balance
        self.initial_balance = initial_balance
        self.available = initial_balance
        self.position: Optional[Position] = None
        self.daily_pnl = 0.0
        self.total_pnl = 0.0
        self.trades_today = 0
        self.risk_config = risk_config
        self.logger = setup_logger(f"account_{account_id}")

    @property
    def total_balance(self) -> float:
        return round(self.balance, 2)

    def check_risk(self, amount_usdt: float) -> Tuple[bool, str]:
        if self.trades_today >= 10:
            return False, "daily_trade_limit"
        risk_pct = amount_usdt / self.balance
        if risk_pct > self.risk_config.get("per_trade", 0.02):
            return False, f"per_trade_risk: {risk_pct:.2%}"
        if abs(self.daily_pnl) / self.initial_balance > self.risk_config.get("daily", 0.05):
            return False, "daily_loss_limit"
        return True, "ok"

    def execute(self, symbol: str, amount_usdt: float, price: float, side: str = "buy") -> Dict:
        ok, reason = self.check_risk(amount_usdt)
        if not ok:
            return {"success": False, "reason": reason}
        quantity = amount_usdt / price
        if side == "buy":
            if amount_usdt > self.available:
                return {"success": False, "reason": "insufficient_balance"}
            self.available -= amount_usdt
            self.position = Position(symbol, quantity, price, "long", time.time())
        else:
            if not self.position:
                return {"success": False, "reason": "no_position"}
            close_value = self.position.amount * price
            self.available += close_value
            pnl = (price - self.position.entry_price) * self.position.amount
            self.daily_pnl += pnl
            self.total_pnl += pnl
            self.position = None
        self.trades_today += 1
        if self.position:
            self.balance = self.available + self.position.amount * price
        else:
            self.balance = self.available
        return {
            "success": True,
            "account_id": self.account_id,
            "balance": round(self.balance, 2),
            "daily_pnl": round(self.daily_pnl, 2),
            "position": self.position.__dict__ if self.position else None
        }

class SimulatedExchange:
    def __init__(self, state_file: str = "/tmp/irisquant_sim_state.json"):
        self.logger = setup_logger("sim_exchange")
        self.state_file = state_file
        # 从统一余额服务获取初始余额
        all_balances = balance_service.get_all_balances()
        self.accounts = {
            "A": SimulatedAccount("A", all_balances.get("A", 10000.0), {"per_trade": 0.02, "daily": 0.05}),
            "B": SimulatedAccount("B", all_balances.get("B", 50000.0), {"per_trade": 0.8, "daily": 0.3}),
            "C": SimulatedAccount("C", all_balances.get("C", 2000.0), {"per_trade": 0.05, "daily": 0.10}),
            "W": SimulatedAccount("W", all_balances.get("W", 500.0), {"per_trade": 0.10, "daily": 0.20}),
        }
        self.prices = {"BTC/USDT": 65000.0, "BTC-PERP": 65100.0}

    def get_price(self, symbol: str) -> float:
        return self.prices.get(symbol, 65000.0)

    def update_price(self, symbol: str, price: float):
        self.prices[symbol] = price

    async def create_order(self, account_id: str, symbol: str, side: str, amount_usdt: float) -> Dict:
        account = self.accounts.get(account_id)
        if not account:
            return {"success": False, "reason": "account_not_found"}
        account._exchange = self
        price = self.get_price(symbol)
        result = account.execute(symbol, amount_usdt, price, side)
        self.save_state()
        return result

    async def close_position(self, account_id: str, symbol: str) -> Dict:
        account = self.accounts.get(account_id)
        if not account or not account.position:
            return {"success": False, "reason": "no_position"}
        price = self.get_price(symbol)
        return account.execute(symbol, 0, price, "sell")

    def save_state(self):
        """保存所有账户余额到文件"""
        state = {
            "accounts": {
                aid: {
                    "balance": acc.balance,
                    "initial_balance": acc.initial_balance,
                    "daily_pnl": acc.daily_pnl,
                    "total_pnl": acc.total_pnl
                }
                for aid, acc in self.accounts.items()
            },
            "timestamp": time.time()
        }
        with open(self.state_file, 'w') as f:
            json.dump(state, f, indent=2)
        self.logger.info(f"已保存余额状态到 {self.state_file}")

sim_exchange = SimulatedExchange()

"""
W 账户适配器 - 独立余额管理，不依赖共享状态文件
"""
import json
import os


class WAccountAdapter:
    def __init__(self, account_id="W"):
        self.account_id = account_id
        self.balance_file = "/root/weather-alpha/data/w_balance.json"
        self.balance = self._load_balance()

    def _load_balance(self):
        """加载余额"""
        if os.path.exists(self.balance_file):
            with open(self.balance_file, 'r') as f:
                data = json.load(f)
                return data.get("balance", 500.0)
        return 500.0

    def _save_balance(self):
        """保存余额"""
        os.makedirs(os.path.dirname(self.balance_file), exist_ok=True)
        with open(self.balance_file, 'w') as f:
            json.dump({"balance": self.balance, "account": self.account_id}, f)

    def get_balance(self):
        return self.balance

    def get_market_price(self, market_id, side):
        return 0.65

    def place_order(self, market_id, side, size, price):
        amount_usdt = size * price
        
        print(f"📋 [W账户] 准备下单: {side} {size:.2f} @ {price:.3f}, 金额: ${amount_usdt:.2f}")

        if amount_usdt > self.balance:
            print(f"❌ [W账户] 余额不足: 需要 ${amount_usdt:.2f}, 可用 ${self.balance:.2f}")
            return {"status": "rejected"}

        # 扣款
        self.balance -= amount_usdt
        self._save_balance()
        
        print(f"✅ [W账户] 买入 {side} {size:.2f} @ {price:.3f}, 花费 ${amount_usdt:.2f}, 余额: ${self.balance:.2f}")

        return {"status": "filled", "balance": self.balance}

    def print_summary(self):
        print("\n" + "=" * 50)
        print("📊 W账户摘要 (独立余额)")
        print("=" * 50)
        print(f"账户ID: {self.account_id}")
        print(f"当前余额: ${self.balance:.2f}")
        print(f"预设资金: $500.00")
        print("=" * 50)

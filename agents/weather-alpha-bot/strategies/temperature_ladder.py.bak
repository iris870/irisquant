import numpy as np
from core.weather_client import NOAAClient
from core.adaptive_bias import AdaptiveBiasCorrector
from core.data_recorder import DataRecorder

class TemperatureLadderStrategy:
    def __init__(self, config, clob, logger):
        self.noaa = NOAAClient()
        self.clob = clob
        self.logger = logger
        self.config = config
        
        self.ladder = [
            {"range": "30-35", "market_id": config.get("TEMP_LADDER_ID_1", "TEMP-30-35-ID")},
            {"range": "35-40", "market_id": config.get("TEMP_LADDER_ID_2", "TEMP-35-40-ID")},
            {"range": "40-45", "market_id": config.get("TEMP_LADDER_ID_3", "TEMP-40-45-ID")},
            {"range": "45-50", "market_id": config.get("TEMP_LADDER_ID_4", "TEMP-45-50-ID")},
            {"range": "50-55", "market_id": config.get("TEMP_LADDER_ID_5", "TEMP-50-55-ID")},
            {"range": "55+",   "market_id": config.get("TEMP_LADDER_ID_6", "TEMP-55PLUS-ID")},
        ]
        
        self.total_budget = float(config.get("LADDER_BUDGET", 50))
        self.station_id = config.get("STATION_ID", "KJFK")
        self.kelly_fraction = float(config.get("KELLY_FRACTION", 0.25))
        self.min_edge = float(config.get("MIN_EDGE", 0.05))
        self.max_position = float(config.get("MAX_POSITION_USD", 100))
        
        self.bias_corrector = AdaptiveBiasCorrector(config)
        self.recorder = DataRecorder()
        
    def _estimate_probability(self, predicted_temp: float, target_low: float, target_high: float = None) -> float:
        """基于正态分布估算温度落在区间的概率（标准差3°F）"""
        std = 3.0
        if target_high is None:  # 处理 55+ 的情况
            z = (target_low - predicted_temp) / std
            prob = 1 - self._normal_cdf(z)
        else:
            z_low = (target_low - predicted_temp) / std
            z_high = (target_high - predicted_temp) / std
            prob = self._normal_cdf(z_high) - self._normal_cdf(z_low)
        return max(0.01, min(0.99, prob))
    
    def _normal_cdf(self, x: float) -> float:
        """标准正态分布CDF近似"""
        t = 1.0 / (1.0 + 0.2316419 * abs(x))
        d = 0.3989423 * np.exp(-x * x / 2.0)
        prob = d * t * (0.3193815 + t * (-0.3565638 + t * (1.781478 + t * (-1.821256 + t * 1.330274))))
        return 1.0 - prob if x >= 0 else prob
    
    def _calculate_size(self, prob: float, price: float) -> float:
        """凯利公式计算仓位"""
        edge = prob - price
        if edge <= 0 or price >= 1.0:
            return 0
        b = (1.0 - price) / price
        q = 1.0 - prob
        kelly = (prob * b - q) / b
        size = self.total_budget * kelly * self.kelly_fraction
        return max(0, min(size, self.max_position))
    
    def run_once(self):
        forecast = self.noaa.get_forecast_by_station(self.station_id)
        if not forecast:
            self.logger.warning("[温度阶梯] 无法获取天气数据")
            return
        
        predicted_temp = forecast.get('temp_f')
        if not predicted_temp:
            return
        
        self.logger.info(f"[温度阶梯] NOAA预测温度: {predicted_temp}°F")
        
        for tier in self.ladder:
            try:
                # 解析温度范围
                if '+' in tier['range']:
                    low = float(tier['range'][:-1])
                    high = None
                else:
                    parts = tier['range'].split('-')
                    low, high = float(parts[0]), float(parts[1])
                
                # 计算基础概率
                base_prob = self._estimate_probability(predicted_temp, low, high)
                
                # 使用自适应偏差修正
                adjusted_prob = self.bias_corrector.get_adjusted_prob(
                    "temperature_ladder", tier['range'], base_prob
                )
                
                market_price = self.clob.get_market_price(tier['market_id'], 'YES')
                edge = adjusted_prob - market_price
                
                # 记录预测
                self.recorder.record_prediction(
                    "temperature_ladder", tier['market_id'], 
                    adjusted_prob, market_price,
                    {"predicted_temp": predicted_temp, "range": tier['range']}
                )
                
                if edge >= self.min_edge:
                    size = self._calculate_size(adjusted_prob, market_price)
                    if size >= 1.0:
                        self.logger.info(f"[温度阶梯] ✅ 买入 {tier['range']}: 概率={adjusted_prob:.1%}, 市价={market_price:.1%}, 优势={edge:.1%}, 金额=${size:.2f}")
                        self.recorder.record_order(
                            "temperature_ladder", tier['market_id'], "YES",
                            size, market_price + 0.01, adjusted_prob, market_price
                        )
                        self.clob.place_order(tier['market_id'], "YES", size, market_price + 0.01)
                else:
                    self.logger.debug(f"[温度阶梯] {tier['range']}: 优势不足 ({edge:.1%} < {self.min_edge:.1%})")
                    
            except Exception as e:
                self.logger.error(f"[温度阶梯] 处理{tier['range']}出错: {e}")

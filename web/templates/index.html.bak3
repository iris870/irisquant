<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IrisQuant v2.1 - 交易看板</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body { background: #0a0e27; font-family: 'JetBrains Mono', monospace; color: #e0e0e0; padding: 24px; }
        .card { background: #11162e; border: 1px solid #2a2e4a; border-radius: 12px; padding: 20px; }
        .stat-number { font-size: 28px; font-weight: bold; }
        .stat-label { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 1px; }
        .positive { color: #00ff88; }
        .negative { color: #ff4444; }
        .agent-row { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 10px; padding: 8px 0; border-bottom: 1px solid #1a1e3a; font-size: 12px; }
    </style>
</head>
<body>
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 pb-4 border-b border-white/10 gap-4">
            <div class="flex items-center gap-4">
                <h1 class="text-2xl font-bold text-emerald-500">IrisQuant v2.1</h1>
                <a href="/analytics" class="text-zinc-400 hover:text-emerald-500 transition text-sm font-bold border-l border-white/10 pl-4">📊 账户表现</a>
                <div class="flex gap-4 px-4 py-1 bg-black/40 rounded-full border border-white/5">
                    <div class="flex items-center gap-2">
                        <span class="text-[9px] text-zinc-500 uppercase font-bold">Binance Market</span>
                        <span id="st-binance" class="text-[10px]">⚪</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-[9px] text-zinc-500 uppercase font-bold">News Source</span>
                        <span id="st-news" class="text-[10px]">⚪</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-[9px] text-zinc-500 uppercase font-bold">Sim Exchange</span>
                        <span id="st-sim" class="text-[10px]">⚪</span>
                    </div>
                </div>
            </div>
            <div class="flex items-center gap-6">
                <div class="text-right">
                    <div class="text-[10px] text-zinc-500 uppercase tracking-widest">Uptime</div>
                    <div id="uptime" class="text-sm font-bold text-white">---</div>
                </div>
                <div class="text-right border-l border-white/10 pl-6">
                    <div class="text-[10px] text-zinc-500 uppercase tracking-widest">RL Data DB</div>
                    <div id="rl-db-status" class="text-sm font-bold text-emerald-500">---</div>
                </div>
                <div class="text-right border-l border-white/10 pl-6">
                    <div class="text-[10px] text-zinc-500 uppercase tracking-widest">Knowledge DB</div>
                    <div id="db-status" class="text-sm font-bold text-amber-500">---</div>
                </div>
                <div class="text-right border-l border-white/10 pl-6">
                    <div class="text-[10px] text-zinc-500 uppercase tracking-widest">Active Agents</div>
                    <div id="agents-status" class="text-sm font-bold text-blue-500">---</div>
                </div>
                <div id="socket-status" class="text-[9px] text-emerald-500 px-2 py-1 bg-emerald-500/10 rounded-lg">● ACTIVE</div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8" id="accounts"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="card">
                <h3 class="text-sm font-bold text-emerald-500 mb-4">📊 实时行情</h3>
                <div id="markets" class="space-y-3"></div>
            </div>
            <div class="card">
                <h3 class="text-sm font-bold text-emerald-500 mb-4">⚙️ Agent 状态</h3>
                <div id="agents" class="max-h-80 overflow-y-auto"></div>
            </div>
        </div>

        <div class="card">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-sm font-bold text-emerald-500">📋 系统实时日志 (PM2 Logs)</h3>
                <div class="flex gap-2">
                    <input type="text" id="log-filter" onkeyup="handleLogSearch(event)" placeholder="搜索 Agent 或 '错误'..." class="bg-black/40 border border-white/10 rounded px-3 py-1 text-xs focus:outline-none focus:border-emerald-500/50 w-64">
                    <button onclick="manualSearch()" class="text-[10px] text-emerald-400 border border-emerald-500/30 rounded px-3 hover:bg-emerald-500/10">搜索</button>
                    <button onclick="clearLogs()" class="text-[10px] text-zinc-500 hover:text-white border border-white/10 rounded px-2">清屏</button>
                </div>
            </div>
            <div id="logs" class="h-96 overflow-y-auto font-mono bg-black/20 p-4 rounded-lg border border-white/5 text-[11px]"></div>
        </div>
    </div>

    <script>
        const ACCOUNT_NAMES = {
            "BINANCE_MAIN": "Binance Main (btc-rolling)",
            "OKX_SUB1": "OKX Sub-Account 1 (contract-trader)",
            "POLYMARKET": "Polymarket (polymarket-bot)",
            "WEATHER_ALPHA": "Weather Alpha (weather-alpha-bot)"
        };

        async function fetchData() {
            try {
                const [accounts, status, markets] = await Promise.all([
                    fetch('/api/accounts').then(r => r.json()),
                    fetch('/api/status').then(r => r.json()),
                    fetch('/api/markets').then(r => r.json())
                ]);

                // 🌟 更新 API 状态灯
                const stBinance = document.getElementById('st-binance');
                const stNews = document.getElementById('st-news');
                const stSim = document.getElementById('st-sim');
                
                if (stBinance) stBinance.innerText = status.binance_market;
                if (stNews) stNews.innerText = status.news_source;
                if (stSim) stSim.innerText = status.sim_exchange;

                // 🌟 更新右上角概览
                const uptimeEl = document.getElementById('uptime');
                const rlDbEl = document.getElementById('rl-db-status');
                const agentsEl = document.getElementById('agents-status');
                const dbEl = document.getElementById('db-status');

                if (uptimeEl) uptimeEl.innerText = status.uptime;
                if (rlDbEl) rlDbEl.innerText = status.rl_db_size;
                if (agentsEl) agentsEl.innerText = `${status.agents_online} / ${status.agents_total}`;
                if (dbEl) dbEl.innerText = status.db_size;

                document.getElementById('accounts').innerHTML = Object.entries(accounts).map(([key, val]) => `
                    <div class="card">
                        <div class="stat-label">${ACCOUNT_NAMES[key] || key}</div>
                        <div class="stat-number">$${val.balance.toLocaleString()}</div>
                        <div class="flex justify-between mt-2">
                            <span class="stat-label">今日盈亏</span>
                            <span class="${val.daily_pnl >= 0 ? 'positive' : 'negative'}">
                                ${val.daily_pnl >= 0 ? '+' : ''}$${val.daily_pnl.toFixed(2)}
                            </span>
                        </div>
                    </div>
                `).join('');

                document.getElementById('markets').innerHTML = Object.entries(markets).map(([coin, data]) => `
                    <div class="flex justify-between items-center py-2 border-b border-zinc-800">
                        <span class="font-bold">${coin}/USDT</span>
                        <span>$${data.price.toLocaleString()}</span>
                        <span class="${data.change >= 0 ? 'positive' : 'negative'}">${data.change >= 0 ? '+' : ''}${data.change}%</span>
                    </div>
                `).join('');

                document.getElementById('agents').innerHTML = status.agents.map(a => `
                    <div class="agent-row">
                        <span>${a.name}</span>
                        <span class="${a.status === 'online' ? 'positive' : 'negative'}">● ${a.status.toUpperCase()}</span>
                        <span>${a.cpu}</span><span>${a.memory}</span><span>${a.restarts}</span>
                    </div>
                `).join('');
            } catch (e) { console.error(e); }
        }

        function clearLogs() {
            document.getElementById('logs').innerHTML = '';
        }

        async function manualSearch() {
            const keyword = document.getElementById('log-filter').value;
            const logsDiv = document.getElementById('logs');
            try {
                const response = await fetch(`/api/logs?limit=100&keyword=${encodeURIComponent(keyword)}`);
                const data = await response.json();
                
                logsDiv.innerHTML = ''; // 搜索时清空旧内容
                data.forEach(item => renderLogLine(item));
            } catch (e) { console.error('Search failed:', e); }
        }

        function handleLogSearch(e) {
            if (e.key === 'Enter') manualSearch();
        }

        function renderLogLine(data) {
            const logsDiv = document.getElementById('logs');
            const text = data.message ? data.message.toLowerCase() : "";
            
            const logItem = document.createElement('div');
            logItem.className = 'py-0.5 border-b border-white/5 opacity-80';
            
            let highlightClass = "";
            if (text.includes('error') || text.includes('failed') || text.includes('exception') || text.includes('错误')) {
                highlightClass = "text-red-400 font-bold";
            }

            logItem.innerHTML = `
                <span class="text-blue-400 mr-2 text-[10px] w-12 inline-block opacity-50 uppercase">[${data.agent}]</span>
                <span class="${highlightClass}">${data.message}</span>
            `;
            
            logsDiv.appendChild(logItem);
            logsDiv.scrollTop = logsDiv.scrollHeight;
            if (logsDiv.childElementCount > 1000) logsDiv.removeChild(logsDiv.firstChild);
        }

        function connectLogSocket() {
            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const socket = new WebSocket(`${protocol}//${window.location.host}/ws/logs/all`);
            const statusEl = document.getElementById('socket-status');
            const logsDiv = document.getElementById('logs');
            const filterInput = document.getElementById('log-filter');

            socket.onopen = () => {
                statusEl.innerText = '● LIVE STREAMING';
                statusEl.className = 'text-[10px] text-emerald-500';
            };

            socket.onmessage = (event) => {
                const data = JSON.parse(event.data);
                const query = filterInput.value ? filterInput.value.toLowerCase() : "";
                
                // 如果搜索框有内容，WebSocket 只渲染匹配的行
                if (query) {
                    const text = data.message ? data.message.toLowerCase() : "";
                    const agent = data.agent ? data.agent.toLowerCase() : "";
                    const isErrorQuery = (query === '错误' || query === 'error') && (text.includes('error') || text.includes('failed') || text.includes('exception') || text.includes('错误'));
                    
                    if (!text.includes(query) && !agent.includes(query) && !isErrorQuery) return;
                }

                renderLogLine(data);
            };

            socket.onclose = () => {
                statusEl.innerText = '● RECONNECTING...';
                statusEl.className = 'text-[10px] text-yellow-500';
                setTimeout(connectLogSocket, 3000);
            };
        }

        fetchData();
        connectLogSocket();
        setInterval(fetchData, 10000);
    </script>
</body>
</html>
